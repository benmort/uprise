{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm -r typecheck)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm --filter admin typecheck)",
      "Bash(pnpm --filter admin typecheck *)",
      "Bash(pnpm --filter admin test)",
      "Bash(pnpm --filter admin test *)",
      "Bash(pnpm --filter api typecheck *)",
      "Bash(pnpm --filter field typecheck)",
      "Bash(pnpm --filter field build)",
      "Bash(NEXT_DIST_DIR=.next-validate pnpm --filter admin build)",
      "Bash(NEXT_DIST_DIR=.next-validate pnpm --filter field build)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(pnpm exec eslint *)",
      "Bash(npx vitest run *)",
      "Bash(pnpm -r build)",
      "Bash(pnpm -r lint)",
      "Bash(pnpm --filter api test:*)",
      "Bash(pnpm --filter api typecheck)",
      "Bash(pnpm --filter admin build)",
      "Bash(pnpm --filter auth build)",
      "Bash(pnpm --filter marketing build)",
      "Bash(pnpm --filter @uprise/db prisma:generate)",
      "Bash(pnpm check:ai-guides)",
      "Bash(node scripts/check-ai-guides.mjs)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(find:*)"
    ],
    "deny": [
      "Bash(prisma migrate dev:*)",
      "Bash(pnpm --filter @uprise/db prisma:migrate:*)"
    ]
  }
}
