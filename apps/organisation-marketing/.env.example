# API the contact/newsletter forms post to (the same public /marketing/* intake the
# product site uses). ngrok dev: https://api.dev.uprise.org.au/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Cloudflare Turnstile site key for the public forms. Empty disables the widget in dev.
# NB: site keys are hostname-scoped — upriselabs.org needs its own key (or add the
# hostname to the existing widget) at deploy.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
