# Field PWA (apps/field, port 3005). All client-exposed (NEXT_PUBLIC_*).

# API base. Dev tunnel: https://api.dev.uprise.org.au/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Standalone auth app — middleware bounces unauthenticated canvassers here.
# Dev tunnel: https://auth.dev.uprise.org.au
NEXT_PUBLIC_AUTH_APP_URL=http://localhost:3002

# This app's own origin (used in copy/links). Prod: https://field.uprise.org.au
NEXT_PUBLIC_FIELD_APP_URL=http://localhost:3005

# Mapbox public token — powers the Walk-view map + walking directions.
# Without it the map/directions are hidden; list mode still works offline.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Web-push public VAPID key (matches the api's VAPID_PUBLIC_KEY) for /field/me.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Force the service worker on in dev (PWA is disabled in dev by default).
# ENABLE_PWA=true
