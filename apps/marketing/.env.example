# API base for the marketing form endpoints (meld doc 12).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Auth app — /sign-up and "Log in" link here (SSO hub).
NEXT_PUBLIC_AUTH_APP_URL=http://localhost:3002
# Admin/organiser app — "Continue as <email>" links here when a session_hint exists.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── ngrok / prog-subdomain dev (see docs/development/ngrok-dev.md) ────────────
# When running `pnpm dev:tunnel`, override these three:
#   NEXT_PUBLIC_API_URL=https://api.dev.uprise.org.au/api/v1
#   NEXT_PUBLIC_AUTH_APP_URL=https://auth.dev.uprise.org.au
#   NEXT_PUBLIC_APP_URL=https://admin.dev.uprise.org.au
