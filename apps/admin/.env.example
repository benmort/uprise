NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Standalone auth app origin (meld doc 14). Middleware + the api-client bounce here
# on a missing/expired session. Dev (lvh.me SSO): http://auth.lvh.me:3002
NEXT_PUBLIC_AUTH_APP_URL=http://localhost:3002

# Parent domain for the shared theme cookie, so the auth app matches the admin's
# light/dark choice across the *.yarns subdomains. Blank = host-only.
NEXT_PUBLIC_COOKIE_DOMAIN=

# ── ngrok / prog-subdomain dev (see docs/development/ngrok-dev.md) ────────────
# When running `pnpm dev:tunnel`, override these:
#   NEXT_PUBLIC_API_URL=https://api.dev.uprise.org.au/api/v1
#   NEXT_PUBLIC_AUTH_APP_URL=https://auth.dev.uprise.org.au
#   NEXT_PUBLIC_COOKIE_DOMAIN=.dev.uprise.org.au

# External integrations UI defaults
NEXT_PUBLIC_ACTION_NETWORK_BASE_URL=https://actionnetwork.org/api/v2
NEXT_PUBLIC_INTERNAL_SOURCE_BASE_URL=

# Public URL of the worker's Bull Board queue dashboard (the /admin/queues path,
# basic-auth gated). Set per-env to the deployed worker host; the admin settings
# page links here. Blank hides the link. Dev: http://localhost:3210/admin/queues
NEXT_PUBLIC_BULLMQ_URL=

# Mapbox publishable token (pk.*) for the Canvass map. List mode works without it.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Set to true to run the PWA service worker under `npm run dev` (offline volunteer
# app). Off by default in dev; production always builds the SW.
ENABLE_PWA=
