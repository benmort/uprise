NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Standalone auth app origin (meld doc 14). Middleware + the api-client bounce here
# on a missing/expired session. Dev (lvh.me SSO): http://auth.lvh.me:3002
NEXT_PUBLIC_AUTH_APP_URL=http://localhost:3002

# ── ngrok / prog-subdomain dev (see docs/development/ngrok-dev.md) ────────────
# When running `pnpm dev:tunnel`, override these two:
#   NEXT_PUBLIC_API_URL=https://api.dev.prog.network/api/v1
#   NEXT_PUBLIC_AUTH_APP_URL=https://auth.dev.prog.network

# External integrations UI defaults
NEXT_PUBLIC_ACTION_NETWORK_BASE_URL=https://actionnetwork.org/api/v2
NEXT_PUBLIC_INTERNAL_SOURCE_BASE_URL=

# Mapbox publishable token (pk.*) for the Canvass map. List mode works without it.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Set to true to run the PWA service worker under `npm run dev` (offline canvasser
# app). Off by default in dev; production always builds the SW.
ENABLE_PWA=
