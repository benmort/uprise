# Auth
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=changeme
# Standalone auth frontend origin — used to build magic-link/reset links (meld doc 14).
AUTH_APP_URL=http://localhost:3002
# Parent domain for the session cookie so subdomain apps share one session (SSO).
# Leave blank for single-host/localhost. MUST be the parent domain with a leading
# dot so every subdomain app shares one session (SSO) — e.g. Prod: .uprise.org.au
# Dev (lvh.me): .lvh.me. A host-only cookie (blank/wrong value) makes admin bounce
# back to auth because admin.<domain> never receives the auth_token set by api.<domain>.
SESSION_COOKIE_DOMAIN=

# ── ngrok / prog-subdomain dev (see docs/development/ngrok-dev.md) ────────────
# When running `pnpm dev:tunnel`, override these four:
#   AUTH_APP_URL=https://auth.dev.uprise.org.au
#   SESSION_COOKIE_DOMAIN=.dev.uprise.org.au
#   API_BASE_URL=https://api.dev.uprise.org.au
#   CORS_ALLOWED_ORIGINS=https://admin.dev.uprise.org.au,https://auth.dev.uprise.org.au,https://dev.uprise.org.au

# API / Runtime
NODE_ENV=development
# Dev only: actually send OTP/2FA SMS via Twilio (needs TWILIO_* set) instead of just
# showing the code on-screen. Default off; ignored in production (which always sends).
DEV_SEND_OTP_SMS=false
PORT=3001
API_BASE_URL=http://localhost:3001
DEFAULT_ORGANIZATION_SLUG=default
# Comma-separated allowlist of browser origins that call the API. EMPTY = allow-all
# (handy for local dev). Non-empty = strict allowlist — every front-end origin must be
# listed. For production use explicit domains only.
# Front-ends: admin (3000), auth (3002), marketing (3003), action/self-signup (3004).
# Example (prod): https://admin.uprise.org.au,https://auth.uprise.org.au,https://action.uprise.org.au
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
CRON_SECRET=
# Preferred stream signing key. Must be identical across all API instances.
STREAM_TOKEN_SECRET=
# Stream token TTL (seconds)
STREAM_TOKEN_TTL_SECONDS=43200
BLAST_SEND_BATCH_SIZE=475
# Batch size used by scheduled dispatch endpoint /blasts/dispatch-due
BLAST_DISPATCH_BATCH_SIZE=95
# Number of blasts claimed per dispatch call
BLAST_DISPATCH_LIMIT=95
# Runtime budget for a single sendNow execution (milliseconds)
BLAST_SEND_MAX_RUN_MS=26600
# BLAST_DRY_RUN is now a platform toggle in the admin Feature flags UI, not set via env.
# CSV import rows processed per start/import batch request
AUDIENCE_IMPORT_BATCH_SIZE=1900
# CSV import rows processed per cron dispatch run
AUDIENCE_IMPORT_DISPATCH_BATCH_SIZE=475
# Number of import jobs claimed per dispatch call
AUDIENCE_IMPORT_DISPATCH_LIMIT=95
# Runtime budget for a single audience import batch execution (milliseconds)
AUDIENCE_IMPORT_MAX_RUN_MS=26600

# BullMQ + Redis
# When FEATURE_BULLMQ_* flags are enabled, this must be a standard Redis URL.
# Local dev: run Redis with `brew services start redis` (or `redis-server`), then:
#   BULLMQ_REDIS_URL=redis://localhost:6379
BULLMQ_REDIS_URL=
BULLMQ_PREFIX=uprise
BULLMQ_DEFAULT_ATTEMPTS=19
BULLMQ_DEFAULT_BACKOFF_MS=570000
BULLMQ_UPLOAD_QUEUE_CONCURRENCY=47
BULLMQ_BLAST_QUEUE_CONCURRENCY=95
BULLMQ_INTEGRATION_SYNC_CONCURRENCY=47

# Blob storage (Vercel Blob) — avatars, tenant files, door-knock photos.
# A static read-write token (local/dev + non-Vercel hosts), or OIDC (VERCEL_OIDC_TOKEN
# + BLOB_STORE_ID) in the Vercel runtime. Dev may reuse the production token: off-
# production, uploads are automatically prefixed with a `development/` key namespace
# (see BLOB_NAMESPACE) so they never collide with real assets at the store root.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
# Key-prefix namespace override. Blank ⇒ "" in production, "development" otherwise.
BLOB_NAMESPACE=

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uprise?schema=public

# Twilio (marketing SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional override. Defaults to ${API_BASE_URL}/api/v1/twilio-status-callback.
TWILIO_STATUS_CALLBACK_URL=
TWILIO_SEND_RATE_PER_SECOND=475
TWILIO_SEND_MAX_CONCURRENT=47
TWILIO_RATE_LIMIT_COOLDOWN_MS=114000

# ── Meld domains (docs 06–14) ────────────────────────────────────────────────
# Transactional SMS (doc 06) — a SEPARATE sender from marketing so carriers
# classify 2FA/verification correctly. Falls back to TWILIO_PHONE_NUMBER if unset.
TWILIO_TRANSACTIONAL_FROM=
TWILIO_TRANSACTIONAL_MESSAGING_SERVICE_SID=
# WhatsApp (existing channel)
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_MESSAGING_SERVICE_SID=
WHATSAPP_SESSION_WINDOW_HOURS=24
# Voice calls (doc 09). url|twiml is required to place a call; callback drives the FSM.
TWILIO_VOICE_FROM=
TWILIO_VOICE_TWIML_URL=
# Optional override. Defaults to ${API_BASE_URL}/api/v1/voice-status-callback.
TWILIO_VOICE_STATUS_CALLBACK_URL=
# Browser voice / WebRTC softphone (doc 09). API key/secret sign the Voice access
# token; the TwiML App's Voice URL must point at ${API_BASE_URL}/api/v1/voice-outbound.
# Platform-account path — per-tenant subaccount voice apps are created lazily. Blank
# ⇒ browser calling is inert (the token endpoint returns 503). Optional recording
# callback override defaults to ${API_BASE_URL}/api/v1/voice-recording-callback.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_VOICE_RECORDING_CALLBACK_URL=
# Transactional email (doc 07). Config-gated: unset = email disabled (logged, not sent).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Optional shared secret for the /email-webhook (SendGrid event POSTs).
SENDGRID_WEBHOOK_SECRET=
# Per-tenant sender subdomain root + DNSimple (used by email provisioning + the
# `email:link-branding` script that manages the click-tracking host, e.g. email.uprise.org.au).
EMAIL_IDENTITY_ROOT_DOMAIN=mail.uprise.org.au
DNSIMPLE_API_TOKEN=
DNSIMPLE_ACCOUNT_ID=
DNSIMPLE_ZONE=uprise.org.au
# Payment (doc 08). STRIPE_WEBHOOK_SECRET is REQUIRED for /payment-webhook (signed).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Integrations
ACTION_NETWORK_API_BASE_URL=https://actionnetwork.org/api/v2
ACTION_NETWORK_API_KEY=
ACTION_NETWORK_SYNC_PER_PAGE=95
ACTION_NETWORK_SYNC_MAX_PAGES=9500
ACTION_NETWORK_SYNC_PAGES_PER_RUN=950
ACTION_NETWORK_SYNC_RUN_BUDGET_MS=114000
ACTION_NETWORK_SYNC_IDENTIFIER_BATCH_SIZE=47
ACTION_NETWORK_SYNC_PERSON_HREF_CONCURRENCY=19
ACTION_NETWORK_SYNC_REQUESTS_PER_SECOND=190
ACTION_NETWORK_SYNC_MAX_RETRIES=9
INTERNAL_SOURCE_API_BASE_URL=
INTERNAL_SOURCE_API_KEY=
# Fallback stream signing key when STREAM_TOKEN_SECRET is blank.
INTEGRATION_CREDENTIAL_SECRET=

# They Vote For You (OpenAustralia Foundation) — politician/policy reference data (civic domain).
# Platform-wide key (per-account, rate-limited); server-side only, never client-exposed.
# Get one at https://theyvoteforyou.org.au/api/ and keep it out of version control.
THEYVOTEFORYOU_API_BASE_URL=https://theyvoteforyou.org.au/api/v1
THEYVOTEFORYOU_API_KEY=
THEYVOTEFORYOU_SYNC_REQUESTS_PER_SECOND=3
THEYVOTEFORYOU_SYNC_MAX_RETRIES=5

# Wikidata SPARQL — state/territory MP roster (civic domain). No key; a descriptive User-Agent
# is required, and the public endpoint rate-limits, so keep the request rate low.
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
WIKIDATA_USER_AGENT=uprise-civic/1.0 (https://uprise.org.au; civic reference data)
WIKIDATA_REQUESTS_PER_SECOND=2
WIKIDATA_MAX_RETRIES=5

# Feature flags are managed in the admin app (Super Admin → Feature flags + Plans),
# not via env. The only remaining env kill-switch is FEATURE_JOURNEYS_ENABLED.

# Compliance
QUIET_HOURS_START=21
QUIET_HOURS_END=8
REQUIRE_OPTOUT_LANGUAGE=true

# Cloudflare Turnstile (bot protection on public forms). Blank secret = guard is a no-op
# (local dev / unconfigured). The matching public site key goes on the front-end apps as
# NEXT_PUBLIC_TURNSTILE_SITE_KEY. Dev: use Cloudflare's always-pass test keys (secret
# 1x0000000000000000000000000000000AA, site key 1x00000000000000000000AA).
TURNSTILE_SECRET_KEY=
TURNSTILE_TIMEOUT_MS=5000

# ── Mapbox (server-side) ──────────────────────────────────────────────────────
# Walking durations for the turf doors/hour estimate, via the Directions API.
# Directions sits in Mapbox's public scope set, so a `pk.` token works. What matters is
# that this is a DIFFERENT token from the browser's NEXT_PUBLIC_MAPBOX_TOKEN: separate
# quota, and it can be rotated without breaking the map. Never URL-restrict it — a server
# sends no Referer, and the estimator would silently fall back to straight lines.
# Absent → the estimator prices the walk with straight lines and labels it as such.
# Directions bills per REQUEST (100k/month free). Matrix bills per origin-destination
# ELEMENT, which is why the estimator does not use it: a 28,580-building turf would be
# 744,375 elements (~$1,191) on Matrix and 1,191 free requests on Directions.
MAPBOX_TOKEN=
# Self-imposed ceiling; Mapbox does not publish a per-minute figure for Directions.
# 429 and Retry-After are honoured regardless.
MAPBOX_DIRECTIONS_RPM=240
