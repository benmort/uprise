{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "node ../../scripts/dev-supervisor.mjs --label api -- nest start --watch",
    "vercel-build": "bash scripts/vercel-build.sh",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest-e2e.config.ts --runInBand",
    "prisma:generate": "pnpm --filter @uprise/db run prisma:generate",
    "prisma:migrate": "pnpm --filter @uprise/db run prisma:migrate",
    "prisma:deploy": "pnpm --filter @uprise/db run prisma:deploy",
    "backfill:contacts": "ts-node src/scripts/backfill-contacts.ts",
    "seed:demo": "ts-node src/scripts/seed-demo.ts",
    "seed:clear": "ts-node src/scripts/seed-demo.ts --clear",
    "seed:plans": "ts-node src/scripts/seed-plans.ts",
    "seed:admin": "ts-node src/scripts/seed-admin-user.ts",
    "reset:tenants": "ts-node src/scripts/reset-to-tenants.ts",
    "geo:map": "ts-node src/scripts/geo/map.ts",
    "geo:chambers": "ts-node src/scripts/geo/backfill-chambers.ts",
    "geo:load-first-nations": "ts-node src/scripts/geo/load-first-nations.ts",
    "geo:first-nations": "ts-node src/scripts/geo/backfill-first-nations.ts",
    "geo:load-boundaries": "ts-node src/scripts/geo/load-boundaries.ts",
    "geo:load-polling-places": "ts-node src/scripts/geo/load-polling-places.ts",
    "insights:load-vic-treaty-poll": "ts-node src/scripts/insights/load-vic-treaty-poll.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@uprise/db": "workspace:*",
    "@uprise/events": "workspace:*",
    "@uprise/flags": "workspace:*",
    "@uprise/permissions": "workspace:*",
    "@vercel/blob": "^2.4.0",
    "bullmq": "^5.76.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.5.6",
    "express": "^4.21.2",
    "geojson-vt": "^3.2.1",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.3.7",
    "uuid": "^11.0.3",
    "vt-pbf": "^3.1.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/geojson-vt": "^3.2.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.3.25",
    "jest": "^29.7.0",
    "shapefile": "^0.6.6",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "xlsx": "^0.18.5"
  }
}
