{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/v1/blasts/dispatch-due",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/v1/audiences/dispatch-imports",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/v1/journeys/sweep-due",
      "schedule": "* * * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
