{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "node dist/worker/src/main.js",
    "dev": "node ../../scripts/dev-supervisor.mjs --label worker -- TS_NODE_PROJECT=tsconfig.dev.json node --watch -r ts-node/register src/main.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "queue:inspect-failed": "ts-node --project tsconfig.dev.json src/admin/queue-admin.ts inspect-failed",
    "queue:replay-failed": "ts-node --project tsconfig.dev.json src/admin/queue-admin.ts replay-failed",
    "queue:drain": "ts-node --project tsconfig.dev.json src/admin/queue-admin.ts drain"
  },
  "dependencies": {
    "@bull-board/api": "^6.7.10",
    "@bull-board/express": "^6.7.10",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@vercel/blob": "^2.4.0",
    "@uprise/db": "workspace:*",
    "@uprise/events": "workspace:*",
    "@uprise/flags": "workspace:*",
    "@uprise/permissions": "workspace:*",
    "bullmq": "^5.76.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.3.7",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.17.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "2.1.9"
  }
}
