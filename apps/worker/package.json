{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "node dist/worker/src/main.js",
    "dev": "TS_NODE_PROJECT=tsconfig.dev.json node --watch -r ts-node/register src/main.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "pnpm run typecheck",
    "build": "tsc -p tsconfig.json",
    "queue:inspect-failed": "ts-node --project tsconfig.dev.json src/admin/queue-admin.ts inspect-failed",
    "queue:replay-failed": "ts-node --project tsconfig.dev.json src/admin/queue-admin.ts replay-failed",
    "queue:drain": "ts-node --project tsconfig.dev.json src/admin/queue-admin.ts drain"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "bullmq": "^5.76.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.3.7",
    "uuid": "^11.0.3",
    "@yarns/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
