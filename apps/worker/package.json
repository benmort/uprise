{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "node dist/worker/src/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "pnpm run typecheck",
    "build": "tsc -p tsconfig.json",
    "queue:inspect-failed": "tsx src/admin/queue-admin.ts inspect-failed",
    "queue:replay-failed": "tsx src/admin/queue-admin.ts replay-failed",
    "queue:drain": "tsx src/admin/queue-admin.ts drain"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "bullmq": "^5.76.8",
    "dotenv": "^16.6.1",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
