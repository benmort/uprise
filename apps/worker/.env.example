# The worker boots the full API NestModule (reactions + outbox relay) and, if this
# file is absent, falls back to apps/api/.env (see main.ts envFileCandidates). Keep
# secrets (Twilio/SendGrid/Stripe) in apps/api/.env to avoid duplication; the worker
# reads them from there. Required here: DATABASE_URL + BULLMQ_REDIS_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yarn_sms?schema=public
DEFAULT_ORGANIZATION_SLUG=default

# Outbox relay poll interval (doc 05). Lower = lower event latency, more DB polls.
OUTBOX_RELAY_INTERVAL_MS=750

BULLMQ_REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=yarns
BULLMQ_DEFAULT_ATTEMPTS=19
BULLMQ_DEFAULT_BACKOFF_MS=570000
BULLMQ_UPLOAD_QUEUE_CONCURRENCY=47
BULLMQ_BLAST_QUEUE_CONCURRENCY=95
BULLMQ_INTEGRATION_SYNC_CONCURRENCY=47

FEATURE_BULLMQ_UPLOAD_ENABLED=true
FEATURE_BULLMQ_BLAST_ENABLED=true
BLAST_DRY_RUN=false

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_SEND_RATE_PER_SECOND=475
TWILIO_SEND_MAX_CONCURRENT=47
TWILIO_RATE_LIMIT_COOLDOWN_MS=114000

ACTION_NETWORK_API_BASE_URL=https://actionnetwork.org/api/v2
ACTION_NETWORK_API_KEY=
ACTION_NETWORK_SYNC_PER_PAGE=95
ACTION_NETWORK_SYNC_MAX_PAGES=9500
ACTION_NETWORK_SYNC_PAGES_PER_RUN=950
ACTION_NETWORK_SYNC_RUN_BUDGET_MS=114000
ACTION_NETWORK_SYNC_IDENTIFIER_BATCH_SIZE=47
ACTION_NETWORK_SYNC_PERSON_HREF_CONCURRENCY=19
ACTION_NETWORK_SYNC_REQUESTS_PER_SECOND=190
ACTION_NETWORK_SYNC_MAX_RETRIES=9
INTERNAL_SOURCE_API_BASE_URL=
INTERNAL_SOURCE_API_KEY=
INTEGRATION_CREDENTIAL_SECRET=
