# API base URL the auth app POSTs to (meld doc 14).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Comma-separated allowlist of origins a successful login may redirect back to.
# Anything not listed falls back to the first entry. Dev (lvh.me) example:
#   http://app.lvh.me:3000,http://admin.lvh.me:3000
NEXT_PUBLIC_ALLOWED_RETURN_ORIGINS=http://localhost:3000,http://localhost:3004,http://localhost:3005

# Action app origin — where /volunteer/[campaignId] sends a freshly-joined volunteer.
# Must also appear in NEXT_PUBLIC_ALLOWED_RETURN_ORIGINS or the redirect falls back.
NEXT_PUBLIC_ACTION_APP_URL=http://localhost:3004

# Marketing site origin — the "Back to homepage" link on /sign-up points here.
NEXT_PUBLIC_MARKETING_URL=http://localhost:3003

# ── ngrok / prog-subdomain dev (see docs/development/ngrok-dev.md) ────────────
# When running `pnpm dev:tunnel`, override these:
#   NEXT_PUBLIC_API_URL=https://api.dev.uprise.org.au/api/v1
#   NEXT_PUBLIC_ALLOWED_RETURN_ORIGINS=https://admin.dev.uprise.org.au,https://field.dev.uprise.org.au,https://action.dev.uprise.org.au
#   NEXT_PUBLIC_ACTION_APP_URL=https://action.dev.uprise.org.au
#   NEXT_PUBLIC_MARKETING_URL=https://dev.uprise.org.au
