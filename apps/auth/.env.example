# API base URL the auth app POSTs to (meld doc 14).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Comma-separated allowlist of origins a successful login may redirect back to.
# Anything not listed falls back to the first entry. Dev (lvh.me) example:
#   http://app.lvh.me:3000,http://admin.lvh.me:3000
NEXT_PUBLIC_ALLOWED_RETURN_ORIGINS=http://localhost:3000

# Marketing site origin — the "Back to homepage" link on /sign-up points here.
NEXT_PUBLIC_MARKETING_URL=http://localhost:3003

# ── ngrok / prog-subdomain dev (see docs/development/ngrok-dev.md) ────────────
# When running `pnpm dev:tunnel`, override these:
#   NEXT_PUBLIC_API_URL=https://api.dev.prog.network/api/v1
#   NEXT_PUBLIC_ALLOWED_RETURN_ORIGINS=https://app.dev.prog.network
#   NEXT_PUBLIC_MARKETING_URL=https://dev.prog.network
