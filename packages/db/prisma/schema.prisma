generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "iam", "tenant", "audience", "messaging", "canvass", "journey", "integration", "analytics", "insights", "events", "email", "ops", "payment", "telephony"]
}

enum AudienceStatus {
  ACTIVE
  ARCHIVED
  @@schema("audience")
}

enum AudienceSource {
  MANUAL
  CSV
  ACTION_NETWORK
  INTERNAL
  @@schema("audience")
}

// Which messaging channel an audience is built for. ALL = usable on any channel
// (the existing/default behaviour); WHATSAPP marks a WhatsApp broadcast list.
enum AudienceChannel {
  SMS
  WHATSAPP
  ALL
  @@schema("audience")
}

// STATIC = a fixed contact list (AudienceContact rows). WHATSAPP_OPTED_IN = a
// dynamic "smart" audience that always resolves to the org's WhatsApp opt-ins.
enum AudienceKind {
  STATIC
  WHATSAPP_OPTED_IN
  @@schema("audience")
}

enum AudienceImportStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  @@schema("audience")
}

enum BlastStatus {
  DRAFTED
  PROOFED
  SCHEDULED
  SENDING
  SENT
  FAILED
  @@schema("messaging")
}

enum BlastRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  RESPONDED
  FAILED
  UNDELIVERED
  SKIPPED
  @@schema("messaging")
}

// Messaging transport for a blast / message / conversation. Distinct from
// EngagementChannel (DOOR/SMS/BOTH), which describes canvassing engagement.
enum MessageChannel {
  SMS
  WHATSAPP
  @@schema("messaging")
}

// Per-contact, per-channel consent. WhatsApp legally requires recorded opt-in;
// SMS stays UNKNOWN (implicit) to preserve today's behaviour.
enum ConsentState {
  UNKNOWN
  OPTED_IN
  OPTED_OUT
  @@schema("messaging")
}

// Marketing vs transactional messages. TRANSACTIONAL (2FA, verification codes,
// receipts) is legally exempt from marketing consent and bypasses
// consent/compliance/suppression (meld doc 06).
enum MessageKind {
  MARKETING
  TRANSACTIONAL
  @@schema("messaging")
}

// Lifecycle of a transactional SMS (mirrors prog's sms-message aggregate).
enum TxSmsStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  UNDELIVERED
  FAILED
  @@schema("messaging")
}

enum IntegrationType {
  ACTION_NETWORK
  INTERNAL
  @@schema("integration")
}

enum IntegrationConnectionStatus {
  ACTIVE
  INACTIVE
  @@schema("integration")
}

enum IntegrationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  @@schema("integration")
}

enum EngagementChannel {
  DOOR
  SMS
  BOTH
  @@schema("canvass")
}

enum QuestionType {
  yes_no
  single_choice
  multi_choice
  text
  scale
  @@schema("canvass")
}

enum DispositionLayer {
  CONTACT_RESULT
  TERMINAL
  DATA_QUALITY
  @@schema("canvass")
}

enum SupportLevel {
  STRONG_SUPPORT
  LEAN_SUPPORT
  UNDECIDED
  LEAN_OPPOSE
  STRONG_OPPOSE
  @@schema("canvass")
}

enum CannedVisibility {
  ORG
  PERSONAL
  AUTO_SEND
  @@schema("canvass")
}

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
  @@schema("journey")
}

enum JourneyRungType {
  wait
  condition
  action
  @@schema("journey")
}

enum JourneyTriggerType {
  disposition_set
  message_received
  tag_added
  survey_answer
  no_answer_after
  @@schema("journey")
}

enum JourneyEnrolmentState {
  ACTIVE
  WAITING
  COMPLETED
  EXITED
  FAILED
  @@schema("journey")
}

enum AppUserRole {
  // OWNER must stay first; migration 20260627100000 inserts it BEFORE ORGANISER so the DB enum
  // order matches this declaration. Do not reorder without a matching migration.
  // VOLUNTEER was renamed from CANVASSER (migration 20260627120000) via ALTER TYPE RENAME VALUE,
  // which preserves position + existing rows. SUPER_ADMIN is NOT here — it's a User.isSuperAdmin
  // boolean (tenant-independent, never selectable in any role picker).
  OWNER
  ORGANISER
  VOLUNTEER
  @@schema("iam")
}

enum CanvassCampaignStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  @@schema("canvass")
}

enum TurfAssignmentStatus {
  // A volunteer self-claim on an approval-required campaign, awaiting an organiser.
  // Does NOT take the exclusive ASSIGNED lock, so several can queue on one turf.
  REQUESTED
  ASSIGNED
  RELEASED
  @@schema("canvass")
}

enum WalkListItemStatus {
  PENDING
  VISITED
  SKIPPED
  @@schema("canvass")
}

enum WalkListItemListType {
  STATIC
  DYNAMIC
  @@schema("canvass")
}

model Tenant {
  id                String                  @id @default(cuid())
  slug              String                  @unique
  name              String
  networkId         String?
  settings          Json?
  // Per-tenant organiser onboarding progress (advisory). Dedicated column rather than a
  // settings.* sub-key: the settings PATCH clobbers the whole blob and is OWNER-only, whereas
  // onboarding is OWNER+ORGANISER and merged monotonically. Shape lives in @uprise/contracts.
  onboarding        Json?
  deletedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  network           Network?                @relation(fields: [networkId], references: [id])
  members           TenantMember[]
  invitations       TenantInvitation[]
  joinRequests      TenantJoinRequest[]
  audiences         Audience[]
  blasts            Blast[]
  integrations      IntegrationConnection[]
  inbound           InboundMessage[]
  outbound          OutboundMessage[]
  snapshots         AnalyticsSnapshot[]
  conversations     ConversationState[]
  consents          ContactConsent[]
  whatsappTemplates WhatsappTemplate[]
  contacts          Contact[]
  scripts           Script[]
  surveys           Survey[]
  cannedResponses   CannedResponse[]
  dispositionDefs   DispositionDef[]
  dispositions      Disposition[]
  questionResponses QuestionResponse[]
  journeys          Journey[]
  canvassCampaigns  CanvassCampaign[]
  polls             Poll[]
  turfs             Turf[]
  turfEstimates     TurfEstimate[]
  walkLists         WalkList[]
  doorKnocks        DoorKnock[]
  shifts            Shift[]
  suppressions      Suppression[]
  pushSubscriptions PushSubscription[]
  apiKeys           ApiKey[]
  storedFiles       StoredFile[]
  featureFlagOverrides FeatureFlagOverride[]

  @@schema("tenant")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  prefix     String
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, revokedAt])
  @@schema("tenant")
}

model StoredFile {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  pathname    String
  url         String
  contentType String?
  sizeBytes   Int
  folder      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, folder])
  @@schema("tenant")
}

// Feature-flag override. Scope = exactly one of: tenant (tenantId set), network
// (networkId set, id-only ref), or global (both null). Uniqueness (one row per
// scope+flag) is enforced by partial unique indexes created in the migration
// (Prisma can't express the WHERE clauses), mirroring the Contact dedup pattern.
model FeatureFlagOverride {
  id        String   @id @default(cuid())
  tenantId  String?
  networkId String?
  flagKey   String
  enabled   Boolean
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, flagKey])
  @@index([networkId, flagKey])
  @@schema("tenant")
}

model Contact {
  id               String            @id @default(cuid())
  tenantId   String
  phoneE164        String?
  addressNorm      String?
  gnafPid          String?           // links to geo.gnaf_address (the G-NAF address universe)
  firstName        String?
  lastName         String?
  email            String?
  address          String?
  lat              Float?
  lng              Float?
  turfId           String?
  canonicalContactId String?         // identity resolution: groups duplicates under one canonical contact
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audienceContacts AudienceContact[]
  recipients       BlastRecipient[]
  inbound          InboundMessage[]
  outbound         OutboundMessage[]
  conversations    ConversationState[]
  consents         ContactConsent[]
  dispositions     Disposition[]
  questionResponses QuestionResponse[]
  journeyEnrolments JourneyEnrolment[]
  turf             Turf?             @relation(fields: [turfId], references: [id], onDelete: SetNull)
  walkListItems    WalkListItem[]
  doorKnocks       DoorKnock[]

  // Dedup is enforced by partial unique indexes (created in the migration):
  //   UNIQUE (tenantId, phoneE164)   WHERE phoneE164   IS NOT NULL
  //   UNIQUE (tenantId, addressNorm) WHERE addressNorm IS NOT NULL
  // Prisma's DSL can't express partial uniques, so they live in migration SQL.
  @@index([tenantId, phoneE164])
  @@index([tenantId, addressNorm])
  @@index([tenantId, turfId])
  @@index([tenantId, gnafPid])
  @@index([tenantId, email])
  @@index([canonicalContactId])
  @@schema("public")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  displayName     String
  passwordHash    String?
  twofaEnabled    Boolean          @default(false)
  twofaSecret     String?
  // Unique so a phone can be a login identifier (phone-first volunteer auth).
  // Postgres treats NULLs as distinct, so many users without a mobile are fine.
  mobile          String?          @unique
  mobileVerified  Boolean          @default(false)
  emailVerified   Boolean          @default(false)
  // Tenant-independent god-mode flag (cross-tenant access). Set by a DB row update only —
  // never via any API/role picker. The single source of truth for SUPER_ADMIN.
  isSuperAdmin    Boolean          @default(false)
  // Signup attribution — where this account came from (utm/source/channel), captured
  // at sign-up so the auth/signup interface can adapt and funnels can be analysed.
  signupSource    String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referrerChannel String?
  lastSignInAt    DateTime?
  deletedAt       DateTime?
  registeredAt    DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  audiences       Audience[]
  blasts          Blast[]
  turfAssignments TurfAssignment[]
  doorKnocks      DoorKnock[]
  sessions        Session[]
  tenantMembers   TenantMember[]

  @@schema("iam")
}

model Audience {
  id             String         @id @default(cuid())
  tenantId String
  createdById    String?
  name           String
  source         AudienceSource
  channel        AudienceChannel @default(ALL)
  kind           AudienceKind    @default(STATIC)
  status         AudienceStatus @default(ACTIVE)
  externalListId String?
  syncedAt       DateTime?
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy      User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  contacts       AudienceContact[]
  imports        AudienceImport[]
  segments       AudienceSegment[]
  blasts         Blast[]

  @@index([tenantId, status])
  @@schema("audience")
}

model AudienceContact {
  id             String      @id @default(cuid())
  tenantId String
  audienceId     String
  contactId      String?
  externalId     String?
  phoneE164      String
  fullName       String?
  metadata       Json?
  source         AudienceSource
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  audience       Audience    @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([audienceId, phoneE164])
  @@index([tenantId, phoneE164])
  @@index([contactId])
  @@schema("audience")
}

model AudienceImport {
  id             String               @id @default(cuid())
  tenantId String
  audienceId     String
  fileName       String
  status         AudienceImportStatus @default(QUEUED)
  cursor         Int                  @default(0)
  totalRows      Int                  @default(0)
  importedRows   Int                  @default(0)
  failedRows     Int                  @default(0)
  csvRaw         String               @db.Text
  errors         Json?
  errorSummary   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  audience       Audience             @relation(fields: [audienceId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@schema("audience")
}

model AudienceSegment {
  id             String              @id @default(cuid())
  tenantId       String
  audienceId     String
  name           String
  type           AudienceSegmentType @default(DYNAMIC)
  definition     Json
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  audience       Audience            @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  members        AudienceSegmentMember[]
  @@index([audienceId, type])
  @@schema("audience")
}

model Blast {
  id             String      @id @default(cuid())
  tenantId String
  audienceId     String?
  createdById    String?
  title          String
  bodyTemplate   String
  channel        MessageChannel @default(SMS)
  contentSid     String?        // WhatsApp: approved Content template SID (HX...)
  contentVariableMap Json?      // WhatsApp: template slot -> personalization key
  status         BlastStatus  @default(DRAFTED)
  scheduledFor   DateTime?
  proofedAt      DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audience       Audience?    @relation(fields: [audienceId], references: [id], onDelete: SetNull)
  createdBy      User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  templates      BlastTemplate[]
  recipients     BlastRecipient[]
  inbound        InboundMessage[]
  outbound       OutboundMessage[]
  snapshots      AnalyticsSnapshot[]

  @@index([tenantId, status])
  @@schema("messaging")
}

model BlastTemplate {
  id        String   @id @default(cuid())
  blastId   String
  version   Int
  body      String
  createdAt DateTime @default(now())
  blast     Blast    @relation(fields: [blastId], references: [id], onDelete: Cascade)

  @@unique([blastId, version])
  @@schema("messaging")
}

model BlastRecipient {
  id              String               @id @default(cuid())
  blastId         String
  contactId       String?
  phoneE164       String
  channel         MessageChannel       @default(SMS)
  renderedBody    String
  status          BlastRecipientStatus @default(PENDING)
  failureCategory String?
  twilioMessageSid String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  respondedAt     DateTime?
  errorCode       String?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  blast           Blast                @relation(fields: [blastId], references: [id], onDelete: Cascade)
  contact         Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([blastId, phoneE164])
  @@index([blastId, status])
  @@index([phoneE164])
  @@index([contactId])
  @@schema("messaging")
}

model InboundMessage {
  id             String        @id @default(cuid())
  tenantId String
  blastId        String?
  contactId      String?
  channel        MessageChannel @default(SMS)
  fromPhone      String
  toPhone        String
  body           String
  mediaUrl       String?
  mediaContentType String?
  twilioMessageSid String?     @unique
  receivedAt     DateTime      @default(now())
  threadKey      String
  createdAt      DateTime      @default(now())
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  blast          Blast?        @relation(fields: [blastId], references: [id], onDelete: SetNull)
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId, threadKey, receivedAt])
  @@index([contactId])
  @@schema("messaging")
}

model OutboundMessage {
  id              String        @id @default(cuid())
  tenantId  String
  blastId         String?
  recipientId     String?
  contactId       String?
  channel         MessageChannel @default(SMS)
  kind            MessageKind   @default(MARKETING)
  txStatus        TxSmsStatus?  // transactional rows; marketing rows use `status`
  purpose         String?       // transactional only: "verification_code" | "2fa" | ...
  toPhone         String
  fromPhone       String
  body            String
  mediaUrl        String?
  mediaContentType String?
  status          BlastRecipientStatus @default(SENT)
  twilioMessageSid String?      @unique
  sentAt          DateTime      @default(now())
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime      @default(now())
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  blast           Blast?        @relation(fields: [blastId], references: [id], onDelete: SetNull)
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId, toPhone, sentAt])
  @@index([tenantId, kind, sentAt])
  @@index([contactId])
  @@schema("messaging")
}

// Transactional message bodies (2FA, verification, receipts), tenant-scoped and
// keyed. Marketing bodies live on Blast; these are for the transactional path.
model MessageTemplate {
  id         String         @id @default(cuid())
  tenantId   String
  key        String
  channel    MessageChannel @default(SMS)
  kind       MessageKind    @default(TRANSACTIONAL)
  type       String?        // freeform classification (mirrors prog template.type)
  category   String?        // grouping/folder (mirrors prog template.category)
  variables  Json?          // declared {{var}} names rendered by this template
  fromNumber String?        // optional sender override (E.164) for this template
  body       String         @db.Text
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([tenantId, key])
  @@schema("messaging")
}

// Per-contact, per-channel messaging consent. WhatsApp requires OPTED_IN before
// business-initiated sends; STOP keywords on either channel set OPTED_OUT.
model ContactConsent {
  id             String         @id @default(cuid())
  tenantId String
  contactId      String?
  phoneE164      String
  channel        MessageChannel
  state          ConsentState   @default(UNKNOWN)
  source         String?        // e.g. "inbound", "stop_keyword", "manual", "import"
  updatedAt      DateTime       @updatedAt
  createdAt      DateTime       @default(now())
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([tenantId, phoneE164, channel])
  @@index([tenantId, channel, state])
  @@index([contactId])
  @@schema("messaging")
}

// Approved WhatsApp message templates synced from the Twilio Content API.
model WhatsappTemplate {
  id             String       @id @default(cuid())
  tenantId String
  contentSid     String       @unique // Twilio Content SID (HX...)
  friendlyName   String
  category       String       // MARKETING | UTILITY | AUTHENTICATION
  language       String       @default("en")
  status         String       @default("pending") // approved | pending | rejected
  variables      Json?        // ordered variable slot names for the composer
  bodyPreview    String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@schema("messaging")
}

model IntegrationConnection {
  id             String                      @id @default(cuid())
  tenantId String
  type           IntegrationType
  name           String
  status         IntegrationConnectionStatus @default(ACTIVE)
  encryptedCredential String
  settings       Json?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  syncJobs       IntegrationSyncJob[]

  @@index([tenantId, type, status])
  @@schema("integration")
}

model IntegrationSyncJob {
  id                    String               @id @default(cuid())
  tenantId        String
  integrationConnectionId String
  audienceId            String?
  status                IntegrationJobStatus @default(QUEUED)
  query                 String?
  remoteListId          String?
  syncedCount           Int                  @default(0)
  failedCount           Int                  @default(0)
  errorSummary          String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime             @default(now())
  connection            IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
  @@schema("integration")
}

model AnalyticsSnapshot {
  id             String      @id @default(cuid())
  tenantId String
  blastId        String?
  metricName     String
  metricValue    Float
  labels         Json?
  bucketAt       DateTime
  createdAt      DateTime    @default(now())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  blast          Blast?       @relation(fields: [blastId], references: [id], onDelete: SetNull)

  @@index([tenantId, metricName, bucketAt])
  @@schema("analytics")
}

model ConversationState {
  id             String      @id @default(cuid())
  tenantId String
  contactId      String?
  contactPhone   String
  channel        MessageChannel @default(SMS)
  unreadCount    Int         @default(0)
  resolved       Boolean     @default(false)
  ownerId        String?     // User id that has claimed this conversation (server-owned)
  claimedAt      DateTime?
  lastMessageAt  DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([tenantId, contactPhone, channel])
  @@index([contactId])
  @@index([tenantId, ownerId])
  @@schema("messaging")
}

// ── Shared engagement layer ──────────────────────────────────────────────
// Script / Survey / Disposition / CannedResponse authored once, consumed by
// BOTH the door-knock UI and the SMS inbox.

model Script {
  id             String            @id @default(cuid())
  tenantId String
  name           String
  channel        EngagementChannel @default(BOTH)
  campaignId     String?
  isArchived     Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps          ScriptStep[]

  @@index([tenantId, channel, isArchived])
  @@schema("canvass")
}

model ScriptStep {
  id           String       @id @default(cuid())
  scriptId     String
  parentStepId String?
  outcomeKey   String?       // disposition code / question-option value leading here from parent
  bodyText     String       @db.Text
  orderIndex   Int          @default(0)
  script       Script       @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  parent       ScriptStep?  @relation("ScriptStepTree", fields: [parentStepId], references: [id], onDelete: Cascade)
  children     ScriptStep[] @relation("ScriptStepTree")

  @@index([scriptId, parentStepId, orderIndex])
  @@schema("canvass")
}

model Survey {
  id             String       @id @default(cuid())
  tenantId String
  name           String
  campaignId     String?
  isArchived     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions      Question[]

  @@index([tenantId, isArchived])
  @@schema("canvass")
}

model Question {
  id         String           @id @default(cuid())
  surveyId   String
  prompt     String           @db.Text
  type       QuestionType
  orderIndex Int              @default(0)
  required   Boolean          @default(false)
  scaleMin   Int?
  scaleMax   Int?
  survey     Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  options    QuestionOption[]
  responses  QuestionResponse[]

  @@index([surveyId, orderIndex])
  @@schema("canvass")
}

// One object, three projections: a survey option renders as a door disposition
// button (label + dispositionCode) AND as an SMS canned reply (cannedReplyText).
model QuestionOption {
  id              String        @id @default(cuid())
  questionId      String
  value           String        // stable machine value, e.g. "yes" / "lean_support"
  label           String        // door button text
  orderIndex      Int           @default(0)
  dispositionCode String?       // picking this option ALSO logs this disposition
  supportLevel    SupportLevel?
  cannedReplyText String?       @db.Text // SMS reply text for this option
  question        Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses       QuestionResponse[]

  @@unique([questionId, value])
  @@index([questionId, orderIndex])
  @@schema("canvass")
}

model QuestionResponse {
  id             String            @id @default(cuid())
  tenantId String
  contactId      String
  questionId     String
  optionId       String?
  valueText      String?           @db.Text
  channel        EngagementChannel
  campaignId     String?
  blastId        String?
  recordedById   String?
  createdAt      DateTime          @default(now())
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  question       Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option         QuestionOption?   @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([tenantId, contactId, createdAt])
  @@index([questionId, optionId])
  @@index([tenantId, recordedById, channel, createdAt], map: "QuestionResponse_recordedBy_idx") // field volunteer-metrics
  @@schema("canvass")
}

// Disposition catalog: tenantId null = system default. Terminal/locked
// codes ship as defaults and cannot be edited.
model DispositionDef {
  id             String            @id @default(cuid())
  tenantId String?
  code           String
  label          String
  layer          DispositionLayer
  channel        EngagementChannel @default(BOTH)
  isTerminal     Boolean           @default(false)
  isLocked       Boolean           @default(false)
  orderIndex     Int               @default(0)
  /// Seconds this outcome takes at the door, for the doors/hour estimate. A PRIOR until
  /// canvass.DoorKnock has rows: consecutive knocks by one volunteer give the real figure.
  expectedSeconds Int?
  tenant   Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, layer, channel])
  @@schema("canvass")
}

// A recorded outcome against a contact. code is denormalised from DispositionDef
// so it survives later edits to the catalog.
model Disposition {
  id               String            @id @default(cuid())
  tenantId   String
  contactId        String
  code             String
  layer            DispositionLayer
  channel          EngagementChannel
  campaignId       String?
  blastId          String?
  scriptStepId     String?
  cannedResponseId String?
  supportLevel     SupportLevel?
  recordedById     String?
  createdAt        DateTime          @default(now())
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId, createdAt])
  @@index([tenantId, code, createdAt])
  @@schema("canvass")
}

// Three-tier visibility. Using a canned reply ALWAYS logs a disposition
// (dispositionCode), which fixes the silent-data-drop antipattern.
model CannedResponse {
  id              String            @id @default(cuid())
  tenantId  String
  ownerId         String?           // set when visibility = PERSONAL
  title           String
  body            String            @db.Text
  channel         EngagementChannel @default(SMS)
  visibility      CannedVisibility  @default(ORG)
  dispositionCode String?
  surveyOptionId  String?
  isArchived      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, channel, visibility, isArchived])
  @@index([tenantId, ownerId])
  @@schema("canvass")
}

// ── Journeys engine ──────────────────────────────────────────────────────
// Cross-channel trigger → wait/condition → action. Door dispositions and text
// replies are first-class triggers; P2P text sends and door tasks are actions.

model Journey {
  id                     String             @id @default(cuid())
  tenantId         String
  name                   String
  status                 JourneyStatus      @default(DRAFT)
  triggerType            JourneyTriggerType
  triggerConfig          Json
  reentryCooldownMinutes Int                @default(0)
  maxActivePerContact    Int                @default(1)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rungs                  JourneyRung[]
  enrolments             JourneyEnrolment[]

  @@index([tenantId, status, triggerType])
  @@schema("journey")
}

model JourneyRung {
  id        String          @id @default(cuid())
  journeyId String
  rungIndex Int
  type      JourneyRungType
  config    Json
  journey   Journey         @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, rungIndex])
  @@schema("journey")
}

model JourneyEnrolment {
  id               String                @id @default(cuid())
  tenantId   String
  journeyId        String
  contactId        String
  currentRungIndex Int                   @default(0)
  state            JourneyEnrolmentState @default(ACTIVE)
  context          Json?
  resumeAt         DateTime?
  lastRungAt       DateTime?
  rungExecCount    Int                   @default(0)
  enrolledAt       DateTime              @default(now())
  completedAt      DateTime?
  journey          Journey               @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  contact          Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([journeyId, contactId, enrolledAt])
  @@index([tenantId, state, resumeAt])
  @@index([journeyId, contactId, state])
  @@schema("journey")
}

// ── Canvassing domain ────────────────────────────────────────────────────
// Turf-cutting, walk lists, server-owned assignment locks, and door knocks
// hung off the Contact spine.

model CanvassCampaign {
  id             String                @id @default(cuid())
  tenantId String
  name           String
  status         CanvassCampaignStatus @default(DRAFT)
  // The campaign's outreach medium — door-knock, SMS, or both. Drives which turf a
  // cut is assigned to and how the campaign is run. Default BOTH keeps existing
  // campaigns unchanged (they predate the field).
  channel        EngagementChannel     @default(BOTH)
  surveyId       String?               // shared-engagement Survey attached to the door script
  scriptId       String?
  goals          Json?                 // { doors, conversations, surveys, ... } pace-to-target targets
  openJoinEnabled Boolean              @default(false) // tokenless self-enrol link active for this campaign
  // Campaign geographic boundary: a cached GeoJSON MultiPolygon built from a union of
  // divisions (sed/ced/lga) + drawn polygons + SAs/meshblocks. `boundarySources` is the
  // re-editable list of parts. Turf-cutting for this campaign is clipped to `boundary`.
  boundary       Json?
  boundarySources Json?
  // Volunteer self-serve turf: master switch + allowed modes (subset of "area"|"draw"|
  // "existing"; null ⇒ all modes when the switch is on).
  volunteerCanSelfClaimTurf Boolean    @default(false)
  selfClaimModes Json?
  // When self-claim is on: true ⇒ a volunteer's claim lands as a REQUESTED assignment
  // an organiser must approve; false ⇒ instant ASSIGNED (the default, existing path).
  turfClaimRequiresApproval Boolean    @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  turfs          Turf[]
  walkLists      WalkList[]
  shifts         Shift[]

  @@index([tenantId, status])
  @@schema("canvass")
}

model Turf {
  id             String       @id @default(cuid())
  tenantId String
  campaignId     String?
  name           String
  geometry       Json         // GeoJSON Polygon / MultiPolygon (source of truth)
  // PostGIS mirror of `geometry`, kept in sync on every create/update, for server-side
  // spatial ops (boundary clip, non-overlap subtract). GIST-indexed in the migration.
  geom           Unsupported("geometry(MultiPolygon, 4326)")?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign       CanvassCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contacts       Contact[]
  walkLists      WalkList[]
  assignments    TurfAssignment[]
  estimate       TurfEstimate?

  @@index([tenantId, campaignId])
  @@schema("canvass")
}

/// How long a turf takes to knock. Derived, cached, and invalidated by `geometryHash` —
/// a re-cut changes the doors, so it must change the estimate.
///
/// `source` records how the walking was priced: "directions" means Mapbox walked the real
/// footpaths; "crowflies" means straight lines, which always flatter the turf. The UI must
/// say which. Every time constant behind `doorSeconds` is a prior until DoorKnock has rows.
model TurfEstimate {
  id               String   @id @default(cuid())
  turfId           String   @unique
  tenantId         String
  doors            Int
  buildings        Int
  doorsPerBuilding Float
  reachableDoors   Float
  walkSeconds      Float
  approachWalkSeconds Float
  entrySeconds     Float
  doorSeconds      Float
  totalSeconds     Float
  doorsPerHour     Float
  doorsPerShift    Int
  shifts           Float
  /// "directions" | "crowflies"
  source           String
  /// Directions requests spent. 0 when the walk was priced with straight lines.
  requests         Int      @default(0)
  /// Hash of the turf geometry the estimate was computed from.
  geometryHash     String
  computedAt       DateTime @default(now())

  turf   Turf   @relation(fields: [turfId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@schema("canvass")
}

model TurfAssignment {
  id          String               @id @default(cuid())
  turfId      String
  volunteerId String
  status      TurfAssignmentStatus @default(ASSIGNED)
  lockedUntil DateTime?
  assignedAt  DateTime             @default(now())
  releasedAt  DateTime?
  turf        Turf                 @relation(fields: [turfId], references: [id], onDelete: Cascade)
  volunteer   User              @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  // One active lock per turf: enforced by a partial unique index in the
  // migration (status = 'ASSIGNED'), so two volunteers can't both own a turf.
  @@index([turfId, status])
  @@index([volunteerId, status])
  @@schema("canvass")
}

model WalkList {
  id             String         @id @default(cuid())
  tenantId String
  campaignId     String?
  turfId         String?
  name           String
  listType       WalkListItemListType @default(STATIC)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign       CanvassCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  turf           Turf?          @relation(fields: [turfId], references: [id], onDelete: SetNull)
  items          WalkListItem[]

  @@index([tenantId, campaignId])
  @@index([turfId]) // field listAssignments joins walk lists by turfId (was a seq scan)
  @@schema("canvass")
}

model WalkListItem {
  id         String             @id @default(cuid())
  walkListId String
  contactId  String
  orderIndex Int                @default(0)
  status     WalkListItemStatus @default(PENDING)
  walkList   WalkList           @relation(fields: [walkListId], references: [id], onDelete: Cascade)
  contact    Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([walkListId, contactId])
  @@index([walkListId, orderIndex])
  @@schema("canvass")
}

// A logged door visit. localId is the client-generated idempotency key so a
// re-synced offline knock is deduped.
model DoorKnock {
  id              String       @id @default(cuid())
  tenantId  String
  contactId       String
  volunteerId     String?
  walkListItemId  String?
  localId         String       // client-generated idempotency key
  dispositionCode String?
  lat             Float?
  lng             Float?
  notes           String?      @db.Text
  photoUrl        String?
  safetyFlag      Boolean?
  clientCapturedAt DateTime?
  createdAt       DateTime     @default(now())
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  volunteer       User?     @relation(fields: [volunteerId], references: [id], onDelete: SetNull)

  @@unique([tenantId, localId])
  @@index([tenantId, contactId, createdAt])
  @@index([volunteerId, createdAt])
  @@schema("canvass")
}

// ── Canvassing UI additions ──────────────────────────────────────────────

// A scheduled canvassing shift: staging location + time window, optionally
// tied to a campaign/turf and a canvasser.
model Shift {
  id             String          @id @default(cuid())
  tenantId String
  campaignId     String?
  turfId         String?
  volunteerId    String?
  name           String
  location       String?
  startsAt       DateTime
  endsAt         DateTime
  notes          String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign       CanvassCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId, campaignId, startsAt])
  @@index([tenantId, volunteerId])
  @@schema("canvass")
}

// QA-review flag resolution. Flags themselves are computed on the fly from DoorKnock
// heuristics (no-GPS / too-fast cadence), so there's no flag entity; this records an
// organiser having actioned a flag. Keyed by (doorKnockId, kind) since one knock can
// raise both kinds. Presence of a row = actioned; `state` distinguishes resolve vs dismiss.
model QaFlagResolution {
  id           String   @id @default(cuid())
  tenantId     String
  campaignId   String
  doorKnockId  String
  kind         String   // "NO_GPS" | "FAST_CADENCE"
  state        String   @default("RESOLVED") // "RESOLVED" | "DISMISSED"
  note         String?
  resolvedById String?
  resolvedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([doorKnockId, kind])
  @@index([tenantId, campaignId])
  @@schema("canvass")
}

// Opt-out / suppression ledger. A phone or email that must never be contacted.
model Suppression {
  id             String          @id @default(cuid())
  tenantId String
  phoneE164      String?
  email          String?
  reason         String?
  source         String?
  createdAt      DateTime        @default(now())
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, phoneE164])
  @@index([tenantId, email])
  @@schema("messaging")
}

// Web-push subscription so organisers can broadcast to canvassers in the field.
model PushSubscription {
  id             String          @id @default(cuid())
  tenantId String
  userId         String?
  endpoint       String
  p256dh         String
  auth           String
  userAgent      String?
  createdAt      DateTime        @default(now())
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, endpoint])
  @@index([tenantId, userId])
  @@schema("public")
}

model Network {
  id                 String   @id @default(cuid())
  name               String
  ownerId            String?
  planName           String?
  subscriptionStatus String?
  createdAt          DateTime @default(now())
  tenants            Tenant[]

  @@index([ownerId])
  @@schema("tenant")
}

model TenantMember {
  id               String      @id @default(cuid())
  tenantId         String
  userId           String
  role             AppUserRole
  // Volunteer onboarding prefs (advisory): preferred canvasser role + usual availability.
  preferredRole    String?
  availabilityDays String[]    @default([])
  // Activity-specific onboarding answers (advisory), e.g. doorknocker walking capability
  // + session length. A JSON bag so new per-activity questions don't need a migration.
  canvassPrefs     Json?
  addedBy          String?
  createdAt        DateTime    @default(now())
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@schema("tenant")
}

model TenantInvitation {
  id        String      @id @default(cuid())
  tenantId  String
  // Exactly one of email / phone is set. Phone invites are delivered by SMS and
  // accepted via the phone-first volunteer flow. Postgres NULLs keep both uniques safe.
  email     String?
  phone     String?
  role      AppUserRole
  status    String
  token     String?     @unique
  expiresAt DateTime?
  invitedBy String?
  createdAt DateTime    @default(now())
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, status])
  @@schema("tenant")
}

/**
 * Prospect-initiated request to join an existing tenant (the inverse of TenantInvitation).
 * status: unverified → pending (after email verification) → approved | rejected. Approval
 * creates the TenantMember. id-only userId ref to iam.User (no cross-schema FK).
 */
model TenantJoinRequest {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  email         String
  phone         String?
  requestedRole String
  status        String
  decidedBy     String?
  decidedAt     DateTime?
  createdAt     DateTime  @default(now())
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@schema("tenant")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String?  // active tenant when the user has multiple memberships (select-tenant)
  token      String   @unique
  userAgent  String?  // captured at login for the active-sessions list
  ipAddress  String?
  lastSeenAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@schema("iam")
}

model MagicLink {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@schema("iam")
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@schema("iam")
}

model MobileVerification {
  id         String    @id @default(cuid())
  // userId is null for a pre-user phone-login challenge (no account yet, or a decoy
  // sent to an unknown number for enumeration resistance). Set for 2FA / mobile-verify.
  userId     String?
  mobile     String?
  code       String
  attempts   Int       @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([mobile])
  @@schema("iam")
}

// ── Outbox + reactions (meld doc 05) ─────────────────────────────────────────
// Domain events written in the same transaction as the state change; a relay
// publishes unpublished rows (FOR UPDATE SKIP LOCKED) onto the domain-events
// queue. Prisma rows stay the source of truth — this is choreography, not
// event-sourcing.
model OutboxEvent {
  id          String    @id @default(cuid())
  seq         BigInt    @default(autoincrement())
  tenantId    String
  eventType   String
  aggregateId String
  payload     Json
  metadata    Json
  occurredAt  DateTime  @default(now())
  publishedAt DateTime?
  attempts    Int       @default(0)

  @@index([publishedAt, seq])
  @@index([tenantId, eventType])
  @@schema("events")
}

// Second-layer idempotency for the reaction consumer (BullMQ jobId is the
// first). One claim per (consumer source, outbox event id).
model ReactionDedup {
  id         String   @id @default(cuid())
  source     String
  eventId    String
  receivedAt DateTime @default(now())

  @@unique([source, eventId])
  @@schema("events")
}

// ── Email domain (meld doc 07) ───────────────────────────────────────────────
enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  BOUNCED
  FAILED
  @@schema("email")
}

model Email {
  id                String      @id @default(cuid())
  tenantId          String
  contactId         String?
  toAddress         String
  subject           String
  status            EmailStatus @default(QUEUED)
  providerMessageId String?
  templateKey       String?
  purpose           String?
  openedAt          DateTime?   // first-write-wins, NOT a status
  clickedAt         DateTime?   // first-write-wins, NOT a status
  bounceReason      String?
  errorMessage      String?
  // Sender provenance (per-tenant identities): stamped at send time so webhook
  // signature-key resolution is by the account that ACTUALLY sent this email,
  // never the tenant's current account. Null = platform env sender.
  emailAccountId    String?
  senderIdentityId  String?
  fromEmail         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([tenantId, status])
  @@index([providerMessageId])
  @@schema("email")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  subject   String
  body      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@schema("email")
}

// ── Email: per-tenant sender identities (SendGrid subusers + domain auth) ───
// Mirrors the telephony models: EmailAccount ↔ TelephonyAccount,
// EmailSenderIdentity ↔ TelephonyPhoneNumber, run/step ↔ provisioning timeline.
enum EmailAccountMode {
  SUBUSER
  BYO
  PLATFORM
  @@schema("email")
}

enum EmailAccountStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  CLOSED
  @@schema("email")
}

enum EmailIdentityKind {
  UPRISE_SUBDOMAIN
  CUSTOM_DOMAIN
  SINGLE_ADDRESS
  @@schema("email")
}

enum EmailIdentityStatus {
  PENDING
  ACTIVE
  REVOKED
  @@schema("email")
}

enum EmailProvisioningStatus {
  REQUESTED
  SUBUSER_CREATED
  DOMAIN_AUTH_CREATED
  DNS_CONFIGURED
  VALIDATION_FAILED
  DOMAIN_VERIFIED
  WEBHOOKS_CONFIGURED
  ACTIVE
  FAILED
  @@schema("email")
}

enum EmailStepStatus {
  STARTED
  SUCCEEDED
  FAILED
  SKIPPED
  @@schema("email")
}

// One SendGrid account (subuser under the platform master, or BYO) per tenant.
// API key encrypted via CredentialCryptoService; webhookPublicKey is the
// subuser's signed-event-webhook key used to verify its callbacks.
model EmailAccount {
  id               String             @id @default(cuid())
  tenantId         String
  mode             EmailAccountMode
  status           EmailAccountStatus @default(PROVISIONING)
  subuserUsername  String?            @unique
  encryptedApiKey  String
  webhookPublicKey String?
  friendlyName     String
  settings         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tenantId, status])
  @@schema("email")
}

// A from-identity: authenticated uprise subdomain, tenant-owned domain, or a
// single verified address. campaignId (id-only ref) scopes to a campaign;
// null = tenant default. dnsRecords holds the CNAMEs shown on the timeline —
// never credentials.
model EmailSenderIdentity {
  id               String              @id @default(cuid())
  tenantId         String
  accountId        String
  campaignId       String?
  kind             EmailIdentityKind
  domain           String
  fromEmail        String
  fromName         String
  sendgridDomainId String?
  dnsRecords       Json?
  purpose          String              @default("marketing")
  status           EmailIdentityStatus @default(PENDING)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([tenantId, campaignId, status])
  @@schema("email")
}

// One provisioning run walks the FSM (see email-provisioning-state.machine.ts).
// resumeStatus records where a FAILED run re-enters on retry.
model EmailProvisioningRun {
  id                String                   @id @default(cuid())
  tenantId          String
  campaignId        String?
  accountId         String?
  identityId        String?
  status            EmailProvisioningStatus  @default(REQUESTED)
  resumeStatus      EmailProvisioningStatus?
  input             Json
  sendgridDomainId  String?
  dnsimpleRecordIds Json?
  lastError         String?
  requestedById     String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  steps             EmailProvisioningStep[]

  @@index([tenantId, status])
  @@schema("email")
}

// Append-only timeline the admin/owner UI reads. detail must never contain
// credentials.
model EmailProvisioningStep {
  id        String               @id @default(cuid())
  runId     String
  tenantId  String
  step      String
  status    EmailStepStatus
  detail    Json?
  error     String?
  createdAt DateTime             @default(now())
  run       EmailProvisioningRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([tenantId, createdAt])
  @@schema("email")
}

// ── Provider webhook idempotency (meld doc 12) ───────────────────────────────
// One claim per (provider, eventId): claim-before-act dedup for SendGrid/Stripe/
// Twilio webhooks. A lost claim means the event was already processed.
model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  eventId    String
  receivedAt DateTime @default(now())

  @@unique([provider, eventId])
  @@schema("ops")
}

// ── Payment domain (meld doc 08) ─────────────────────────────────────────────
enum PaymentStatus {
  RECORDED
  PROCESSING
  SUCCEEDED
  PARTIALLY_REFUNDED
  FAILED
  REFUNDED
  @@schema("payment")
}

enum PaymentType {
  SUBSCRIPTION
  ONE_TIME
  INVOICE
  REFUND
  @@schema("payment")
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  networkId         String?
  amountCents       Int
  currency          String
  customerRef       String?
  providerPaymentId String?       @unique
  status            PaymentStatus @default(RECORDED)
  type              PaymentType
  refundedCents     Int           @default(0)
  subscriptionId    String?
  invoiceId         String?
  failureReason     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  refunds           Refund[]

  @@index([tenantId, status])
  @@schema("payment")
}

model Refund {
  id                String   @id @default(cuid())
  paymentId         String
  amountCents       Int
  status            String // created | processing | succeeded | failed
  processorRefundId String?
  reason            String?
  createdAt         DateTime @default(now())
  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  // One refund row per (payment, provider refund id) — blocks duplicate refunds
  // from replayed/concurrent webhook events. NULL processorRefundId (manual
  // refunds) stays distinct, so multiple manual refunds per payment are allowed.
  @@unique([paymentId, processorRefundId])
  @@index([paymentId])
  @@schema("payment")
}

model Customer {
  id                 String   @id @default(cuid())
  networkId          String?
  tenantId           String?
  providerCustomerId String   @unique
  email              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@schema("payment")
}

model Subscription {
  id                     String    @id @default(cuid())
  tenantId               String
  providerSubscriptionId String    @unique
  status                 String
  planName               String?
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@schema("payment")
}

// Subscription plan / tier. `key` matches Network.planName (and the Stripe price
// nickname). `featureFlags` is the entitlement set this plan grants — a map of
// feature-flag key → bool, the "plan" layer in flag resolution.
model Plan {
  id           String    @id @default(cuid())
  key          String    @unique
  displayName  String
  featureFlags Json
  isDefault    Boolean   @default(false)
  archivedAt   DateTime?
  // ── Marketing/pricing + visibility (editable via the admin Plans page) ──
  // publiclyVisible=false hides a plan from the public pricing page (super-admin only).
  publiclyVisible       Boolean @default(true)
  order                 Int     @default(0)
  popular               Boolean @default(false)
  description           String?
  priceMonthly          Int?
  priceMonthlyOriginal  Int?
  priceAnnually         Int?
  priceAnnuallyOriginal Int?
  // Enforced per-tenant limits: { contacts, teamMembers, segments }; a null/absent member = unlimited.
  limits                Json?
  // Display-only feature-table column for the pricing page: [{ label, value: boolean|string }].
  features              Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@schema("payment")
}

model Invoice {
  id                String   @id @default(cuid())
  tenantId          String
  providerInvoiceId String   @unique
  status            String
  amountCents       Int
  currency          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@schema("payment")
}

model PaymentMethod {
  id               String   @id @default(cuid())
  customerId       String
  providerMethodId String   @unique
  brand            String?
  last4            String?
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([customerId])
  @@schema("payment")
}

// ── Audience fold-in (meld doc 10) ───────────────────────────────────────────
enum AudienceSegmentType {
  STATIC
  DYNAMIC
  @@schema("audience")
}

// Multi-source provenance for a Contact — lets a contact be reconciled across
// source systems (Action Network, CSV, ...) and re-resolved. 1:1 with prog's
// source_record_view.
model ContactSourceRecord {
  id           String   @id @default(cuid())
  tenantId     String
  contactId    String   // id-only ref to public.Contact
  sourceSystem String
  externalId   String
  data         Json?
  createdAt    DateTime @default(now())

  @@unique([sourceSystem, externalId])
  @@index([contactId])
  @@index([tenantId, sourceSystem])
  @@schema("audience")
}

// Materialised membership of a DYNAMIC AudienceSegment (rewritten by the
// SegmentEvaluatorService). id-only contactId ref to public.Contact.
model AudienceSegmentMember {
  segmentId  String
  contactId  String
  computedAt DateTime @default(now())
  segment    AudienceSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([segmentId, contactId])
  @@index([contactId])
  @@schema("audience")
}

// ── Telephony: voice calls (meld doc 09) ─────────────────────────────────────
enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  BUSY
  NO_ANSWER
  FAILED
  @@schema("telephony")
}

// One outbound voice call. Net-new to uprise (SMS/WhatsApp live in messaging).
// id-only contactId ref to public.Contact (cross-schema decoupling rule).
model Call {
  id              String     @id @default(cuid())
  tenantId        String
  contactId       String?
  toNumber        String
  fromNumber      String
  status          CallStatus @default(INITIATED)
  providerCallId  String?    @unique
  durationSeconds Int?
  recordingUrl    String?
  priceCents      Int?
  currency        String?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([tenantId, status])
  @@schema("telephony")
}

// ── Telephony: per-tenant Twilio accounts + AU number provisioning ──────────
// One Twilio account (auto-provisioned subaccount or BYO credentials) per
// tenant. Auth token encrypted at rest via CredentialCryptoService (the
// IntegrationConnection pattern). id-only tenantId ref.
enum TelephonyAccountMode {
  SUBACCOUNT
  BYO
  PLATFORM
  @@schema("telephony")
}

enum TelephonyAccountStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  CLOSED
  @@schema("telephony")
}

enum TelephonyNumberStatus {
  PENDING
  ACTIVE
  RELEASED
  @@schema("telephony")
}

enum TelephonyProvisioningStatus {
  REQUESTED
  SUBACCOUNT_CREATED
  COMPLIANCE_DRAFT
  COMPLIANCE_SUBMITTED
  COMPLIANCE_APPROVED
  COMPLIANCE_REJECTED
  NUMBER_PURCHASED
  WEBHOOKS_CONFIGURED
  ACTIVE
  FAILED
  @@schema("telephony")
}

enum TelephonyStepStatus {
  STARTED
  SUCCEEDED
  FAILED
  SKIPPED
  @@schema("telephony")
}

model TelephonyAccount {
  id                 String                 @id @default(cuid())
  tenantId           String
  mode               TelephonyAccountMode
  status             TelephonyAccountStatus @default(PROVISIONING)
  accountSid         String                 @unique
  encryptedAuthToken String
  friendlyName       String
  settings           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([tenantId, status])
  @@schema("telephony")
}

// A provisioned number maps to exactly ONE account. campaignId (id-only ref to
// canvass.CanvassCampaign) scopes a number to a campaign; null = tenant default.
// phoneNumberE164 is the inbound-webhook tenant-resolution key.
model TelephonyPhoneNumber {
  id              String                @id @default(cuid())
  tenantId        String
  accountId       String
  campaignId      String?
  phoneNumberE164 String                @unique
  phoneNumberSid  String                @unique
  bundleSid       String?
  addressSid      String?
  purpose         String                @default("marketing")
  status          TelephonyNumberStatus @default(PENDING)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([tenantId, campaignId, status])
  @@schema("telephony")
}

// One provisioning run walks the FSM (see telephony-provisioning-state.machine.ts).
// resumeStatus records where a FAILED run re-enters on retry. bundleSid is the
// bundle-status-webhook resolution key.
model TelephonyProvisioningRun {
  id              String                       @id @default(cuid())
  tenantId        String
  campaignId      String?
  accountId       String?
  status          TelephonyProvisioningStatus  @default(REQUESTED)
  resumeStatus    TelephonyProvisioningStatus?
  complianceInput Json
  documents       Json?
  bundleSid       String?                      @unique
  addressSid      String?
  endUserSid      String?
  phoneNumberId   String?
  lastError       String?
  requestedById   String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  steps           TelephonyProvisioningStep[]

  @@index([tenantId, status])
  @@schema("telephony")
}

// Append-only timeline read by the admin/owner provisioning UI. detail must
// never contain credentials.
model TelephonyProvisioningStep {
  id        String                   @id @default(cuid())
  runId     String
  tenantId  String
  step      String
  status    TelephonyStepStatus
  detail    Json?
  error     String?
  createdAt DateTime                 @default(now())
  run       TelephonyProvisioningRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([tenantId, createdAt])
  @@schema("telephony")
}

// ── Org records & user profiles (meld doc 11) ────────────────────────────────
// OrgProfile is the legal/operational record of the organisation a tenant
// represents — distinct from Tenant (the data-isolation boundary, doc 03).
// 1:1 translation of prog's organisation_*_view tables. id-only tenantId ref.
model OrgProfile {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  // Public profile + brand. Rendered on the tenant's auth/marketing surfaces
  // (see Tenant.brandBySlug). Logos come in two shapes: block (≈square) and
  // landscape; favicon + hero are single images. Colours are hex strings.
  bio              String?
  websiteUrl       String?
  facebookUrl      String?
  twitterUrl       String?
  linkedinUrl      String?
  instagramUrl     String?
  logoBlockUrl     String?
  logoLandscapeUrl String?
  faviconUrl       String?
  heroImageUrl     String?
  primaryColour    String?
  secondaryColour  String?
  customCss        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contacts   OrgContact[]
  addresses  OrgAddress[]
  credential OrgCredential?

  @@index([tenantId])
  @@schema("tenant")
}

model OrgContact {
  id                    String  @id @default(cuid())
  orgProfileId          String
  firstName             String?
  lastName              String?
  email                 String?
  phone                 String?
  mobilePhone           String?
  title                 String?
  role                  String?
  contactType           String?
  isPrimaryContact      Boolean @default(false)
  isAuthorisedSignatory Boolean @default(false)
  orgProfile            OrgProfile @relation(fields: [orgProfileId], references: [id], onDelete: Cascade)

  @@index([orgProfileId])
  @@schema("tenant")
}

model OrgAddress {
  id           String  @id @default(cuid())
  orgProfileId String
  addressType  String?
  line1        String?
  line2        String?
  suburb       String?
  city         String?
  state        String?
  country      String?
  postcode     String?
  orgProfile   OrgProfile @relation(fields: [orgProfileId], references: [id], onDelete: Cascade)

  @@index([orgProfileId])
  @@schema("tenant")
}

model OrgCredential {
  id                       String  @id @default(cuid())
  orgProfileId             String  @unique
  legalTradingName         String?
  australianBusinessNumber String?
  australianCompanyNumber  String?
  taxFileNumber            String?  // ENCRYPTED at rest (CredentialCryptoService)
  industry                 String?
  entityType               String?
  registrationNumber       String?
  isRegisteredEntity       Boolean @default(false)
  acncRegistrationNumber   String?
  acncStatus               String?
  charitySubtype           String?
  deductibleGiftRecipient  Boolean @default(false)
  dgrStatus                String?
  financialYearEnd         String?
  orgProfile               OrgProfile @relation(fields: [orgProfileId], references: [id], onDelete: Cascade)

  @@schema("tenant")
}

// User profile + avatars (iam schema). id-only userId refs to iam.User.
model UserProfile {
  userId        String    @id
  displayName   String?
  givenName     String?
  familyName    String?
  phone         String?
  avatarUrl     String?
  bio           String?
  dateOfBirth   DateTime?
  facebookUrl   String?
  twitterUrl    String?
  linkedinUrl   String?
  instagramUrl  String?
  websiteUrl    String?

  @@schema("iam")
}

model UserAvatar {
  id         String  @id @default(cuid())
  userId     String
  url        String
  isSelected Boolean @default(false)

  @@index([userId])
  @@schema("iam")
}

// ─────────────────────────────────────────────────────────────────────────────
// insights — public-opinion polls attached to geo regions (see docs/insights/).
// Tenant-owned + shareable: a nullable tenantId (owned when set, a shared/global
// tier when null, mirroring FeatureFlagOverride). Estimates reference geo regions
// id-only by (geoKind, geoCode) — geo.* is raw PostGIS, not a Prisma schema, so
// there is no FK to a region. The partial-unique slug indexes (tenant vs global)
// are hand-written in the migration (Prisma can't express the WHERE clause).
// ─────────────────────────────────────────────────────────────────────────────

enum PollStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("insights")
}

model Poll {
  id             String     @id @default(cuid())
  /// Tenant-owned when set; a shared/global tier when null (super-admin-gated).
  tenantId       String?
  slug           String
  title          String
  source         String // fieldwork agency, e.g. "YouGov"
  commissioner   String? // e.g. "Common Threads"
  fieldworkStart DateTime?
  fieldworkEnd   DateTime?
  sampleSize     Int?
  methodology    String?
  /// Jurisdiction the geographic breakdowns cover, e.g. "VIC".
  geoScope       String?
  weighted       Boolean    @default(true)
  licence        String?
  attribution    String?
  /// Curated key findings from the summary: [{ heading, body, questionCode? }].
  keyFindings    Json?
  status         PollStatus @default(DRAFT)
  /// Cross-tenant visibility. A tenant-owned poll (tenantId set) is private to that tenant
  /// until an OWNER/ORGANISER of that tenant (or a super-admin) makes it public; then every
  /// tenant can read it. Kept separate from tenantId so ownership survives publishing and the
  /// toggle is reversible. Null-tenant polls are the super-admin global tier and always shared.
  isPublic       Boolean    @default(false)
  publishedAt    DateTime?
  // Ingest provenance (the tenant analogue of geo.dataset_meta, carried on the row).
  sourceFileName String?
  sourceFileHash String?
  lastIngestedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant    Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions PollQuestion[]
  estimates PollEstimate[]

  @@index([tenantId, status])
  @@schema("insights")
}

model PollQuestion {
  id           String  @id @default(cuid())
  pollId       String
  /// Denormalised from Poll for tenant-isolation on estimate reads.
  tenantId     String?
  code         String // "C5", "C3_1", "D6"
  title        String
  category     String? // "treaty" | "polling_background" | "open_ended"
  sheet        String?
  ordinal      Int     @default(0)
  hasNet       Boolean @default(false)
  responseKind String? // "support_oppose" | "single_choice" | "agree_disagree" | "open"

  poll      Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  estimates PollEstimate[]

  @@unique([pollId, code])
  @@index([pollId, ordinal])
  @@schema("insights")
}

model PollEstimate {
  id              String   @id @default(cuid())
  pollId          String
  questionId      String
  /// Denormalised for tenant-isolation on the hot read path.
  tenantId        String?
  responseLabel   String // "Strongly support" | "NET Support" | "Total"
  responseOrdinal Int      @default(0)
  isNet           Boolean  @default(false)
  breakdownGroup  String // "Total" | "Gender" | "VIC Upper House Electorate" | "Region"
  breakdownValue  String // "Total" | "Male" | "Eastern Victoria"
  /// Source column index — orders crosstab columns as they appeared in the sheet.
  breakdownOrdinal Int     @default(0)
  /// Set only for geographic breakdowns: "sed_upper" now, "sed_lower" (MRP) later.
  geoKind         String?
  /// Resolved geo region code (id-only reference to geo.* — no FK).
  geoCode         String?
  percent         Decimal? @db.Decimal(5, 2)
  baseN           Int?
  /// baseN meets the reportability threshold.
  reportable      Boolean  @default(true)

  poll     Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  question PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, responseLabel, breakdownGroup, breakdownValue])
  @@index([pollId, geoKind, geoCode])
  @@index([questionId, breakdownGroup])
  @@index([tenantId])
  @@schema("insights")
}
