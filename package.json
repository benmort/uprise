{
  "name": "twilio-messenger",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "clean:next": "rm -rf apps/*/.next apps/*/.next-validate",
    "dev:all": "concurrently -n apps,worker,tunnel -c blue,cyan,magenta \"pnpm dev:apps\" \"pnpm dev:worker\" \"pnpm dev:tunnel\"",
    "dev:apps": "pnpm -r --parallel --filter=!worker run dev",
    "dev:api": "pnpm --filter api run dev",
    "dev:admin": "pnpm --filter admin run dev",
    "dev:auth": "pnpm --filter auth run dev",
    "dev:product-marketing": "pnpm --filter product-marketing run dev",
    "dev:organisation-marketing": "pnpm --filter organisation-marketing run dev",
    "dev:action": "pnpm --filter action run dev",
    "dev:worker": "pnpm --filter worker run dev",
    "dev:tunnel": "ngrok start --config ngrok.local.yml --config ngrok.yml --all",
    "dev:fresh": "bash scripts/dev.sh",
    "kill:ports": "bash scripts/kill-ports.sh",
    "reset:tenants": "pnpm --filter api run reset:tenants",
    "load:queue-dispatch": "node scripts/load/queue-dispatch-load.mjs",
    "shadow:compare-queues": "node scripts/shadow/compare-queue-outcomes.mjs",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "check:ai-guides": "node scripts/check-ai-guides.mjs",
    "coverage:check": "node scripts/coverage-check.mjs",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "gen:sitemap": "node scripts/gen-sitemap.mjs"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
